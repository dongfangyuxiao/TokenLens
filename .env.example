# GitHub
GITHUB_TOKEN=ghp_xxxxxx
GITHUB_USERNAME=your_username        # 个人账号用，组织账号留空
GITHUB_ORG=your_org                  # 组织账号用，个人账号留空

# GitLab
GITLAB_TOKEN=glpat-xxxxxx
GITLAB_URL=https://gitlab.com        # 私有部署改成对应地址

# LLM
DEEPSEEK_API_KEY=sk-xxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxx

# 邮件
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your@qq.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=your@qq.com
EMAIL_TO=receiver1@example.com,receiver2@example.com

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# 其他
SCAN_INTERVAL_HOURS=1               # 扫描近多少小时的提交
MAX_DIFF_CHARS=12000                # 单文件 diff 最大字符数（超出截断）
